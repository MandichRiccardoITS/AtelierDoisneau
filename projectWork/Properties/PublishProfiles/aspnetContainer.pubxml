<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121. -->
<Project>
	<PropertyGroup>
		<!-- Metodo di pubblicazione su cartella locale -->
		<WebPublishMethod>FileSystem</WebPublishMethod>
		<LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
		<LastUsedPlatform>Any CPU</LastUsedPlatform>
		<ExcludeApp_Data>False</ExcludeApp_Data>

		<!-- Percorso di output locale dove verranno salvati i file -->
		<publishUrl>..\compiled\</publishUrl>
		<DeleteExistingFiles>True</DeleteExistingFiles>

		<!-- CONFIGURAZIONE PER LINUX -->
		<TargetFramework>net10.0</TargetFramework>
		<!-- Sostituisci con la tua versione (es. net6.0 o net9.0) -->
		<RuntimeIdentifier>linux-x64</RuntimeIdentifier>

		<!-- MODALITÀ: Dipendente dal framework (non include il runtime nel pacchetto) -->
		<SelfContained>false</SelfContained>

		<!-- DISABILITA ONE-FILE: Assicura che i file non siano uniti in un unico eseguibile -->
		<PublishSingleFile>false</PublishSingleFile>

		<!-- Altre ottimizzazioni opzionali -->
		<PublishReadyToRun>false</PublishReadyToRun>
		<PublishTrimmed>false</PublishTrimmed>
	</PropertyGroup>
</Project>